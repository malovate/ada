# ============================================================
# .env.example — Environment Variables Template
# ============================================================
# Copy this file and rename it to '.env'
# Fill in your actual values.
# NEVER commit .env to GitHub — add it to .gitignore
# ============================================================

# Your Anthropic API key — Ada's brain
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — used ONLY for Whisper voice transcription
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ElevenLabs API key — Ada's voice (TTS)
# Get it from: https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Ada's Voice ID — Rachel (warm, calm, intelligent)
# Rachel's ID is already hardcoded as default in voice.py
# but always set it here explicitly so you can swap without touching code
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Environment (development or production)
ENVIRONMENT=development
