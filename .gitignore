# ============================================================
# .gitignore — files Git should NEVER track or push to GitHub
# ============================================================
# A .gitignore file tells Git: "pretend these files don't exist."
# This protects secrets, skips large auto-generated folders,
# and keeps your repo clean.
# ============================================================

# ── Secrets — the most important section ─────────────────────
# NEVER commit real API keys. If they reach GitHub, even in a
# private repo, bots scan for them within minutes and steal them.
.env
.env.local
.env.production.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/

# ── Database files — these are data, not code ─────────────────
# They'd bloat your repo and conflict between machines.
backend/*.db
backend/.chroma/

# ── Node / JavaScript ─────────────────────────────────────────
# node_modules is enormous (often 200MB+). Never commit it.
# Anyone who clones the repo runs 'npm install' to regenerate it.
# node_modules/
**/node_modules/
webapp/node_modules/
webapp/node_modules

# Vite build output — regenerated by 'npm run build'
webapp/dist/

# ── OS generated files ────────────────────────────────────────
.DS_Store          # Mac
Thumbs.db          # Windows
Desktop.ini        # Windows

# ── Editor files ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
